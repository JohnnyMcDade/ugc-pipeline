# Copy to `.env` and fill in. main.py loads this on startup.

# --- LLM ---
ANTHROPIC_API_KEY=

# --- HeyGen (org-level — one key powers all 3 TikTok accounts) ---
HEYGEN_API_KEY=

# --- Account 1: @sharpguylab ---
TIKTOK_SESSION_SHARPGUYLAB=
TIKTOK_BUSINESS_ID_SHARPGUYLAB=
TIKTOK_SHOP_AFFILIATE_ID_SHARPGUYLAB=

# --- Account 2: @rideupgrades ---
TIKTOK_SESSION_RIDEUPGRADES=
TIKTOK_BUSINESS_ID_RIDEUPGRADES=
TIKTOK_SHOP_AFFILIATE_ID_RIDEUPGRADES=

# --- Account 3: @passivepoly ---
TIKTOK_SESSION_PASSIVEPOLY=
TIKTOK_BUSINESS_ID_PASSIVEPOLY=
PASSIVEPOLY_BACKEND_URL=https://your-railway-app.up.railway.app
PASSIVEPOLY_BACKEND_TOKEN=

# --- TikTok developer app (org-level OAuth credentials) ---
# Used by tiktok_oauth.py / get_token.py to mint per-account access tokens.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Sandbox app credentials (optional, parallel to production above).
# When set, `python tiktok_oauth.py <handle> --sandbox` uses these and writes
# tokens to TIKTOK_SANDBOX_SESSION_<HANDLE> / _BUSINESS_ID_<HANDLE> /
# _REFRESH_TOKEN_<HANDLE> so production tokens stay untouched.
TIKTOK_SANDBOX_CLIENT_KEY=
TIKTOK_SANDBOX_CLIENT_SECRET=

# --- Shared scrapers ---
TIKTOK_CC_SESSION=
TIKTOK_SCRAPER_SESSION=

# --- Whop (passivepoly subscription stats) ---
WHOP_API_KEY=

# --- Agent 10 (self-repair monitor) ---
# Discord incoming-webhook URL for auto-repair alerts + daily 7am report.
# Create at: Discord server settings → Integrations → Webhooks → New Webhook.
# Use a PRIVATE channel — alerts include error details and may leak internal paths.
# If unset, Agent 10 still runs and self-repairs; it just won't post to Discord.
DISCORD_WEBHOOK_REPAIR=
